{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "nuxt": {
      "type": "remote",
      "url": "https://nuxt.com/mcp",
      "enabled": true
    },
    "nuxt-ui": {
      "type": "remote",
      "url": "https://ui.nuxt.com/mcp",
      "enabled": true
    },
    "directus": {
      "type": "local",
      "command": ["npx", "-y", "@directus/content-mcp@latest"],
      "enabled": true,
      "environment": {
        "DIRECTUS_URL": "http://localhost:8055",
        "DIRECTUS_USER_EMAIL": "admin@example.com",
        "DIRECTUS_USER_PASSWORD": "supersecret"
      }
    }
  }
}
